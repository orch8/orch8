# Orch8 configuration
# Copy to `.env` and edit, or export these in your shell.
# `~/.orch8/config.yaml` is read first; these env vars override it.

# Network
# Default loopback. Setting to 0.0.0.0 or a LAN IP exposes the API to the network
# — read the Security section of README.md before doing so.
ORCH_HOST=localhost
ORCH_PORT=3847

# Embedded Postgres
ORCH_PG_PORT=5433
ORCH_DB_PASSWORD=orch8-dev

# Scheduler tick interval (ms). Lower = faster response to wakeups, higher load.
ORCH_SCHEDULER_INTERVAL_MS=60000

# Path to the admin bearer token (generated on first boot, mode 0600)
# Defaults to ~/.orch8/admin-token if unset.
# ORCH_ADMIN_TOKEN_PATH=

# Claude credentials
ANTHROPIC_API_KEY=

# Daemon log level: trace | debug | info | warn | error
LOG_LEVEL=info
